{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/leetcode/index.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/api/leetcode",
      "destination": "/api/leetcode/index.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
